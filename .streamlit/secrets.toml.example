# Access-IQ Dashboard - Streamlit Cloud Secrets
# Copy this file to .streamlit/secrets.toml and fill in values.
# NEVER commit secrets.toml - it is gitignored.
#
# Retrieve credentials from CloudFormation outputs after `make infra-deploy`:
#   aws cloudformation describe-stacks --stack-name <iam-stack> \
#     --query "Stacks[0].Outputs"

AWS_ACCESS_KEY_ID = "AKIA..."
AWS_SECRET_ACCESS_KEY = "your-secret-key-here"
AWS_REGION = "eu-west-2"
PLATFORM_BUCKET = "access-iq-dev-123456789012"

# Runtime config for access-iq (12-factor). Copy to .env and fill.
# .env is gitignored; .env.example is the committed schema.
#
# NOTE: Phase 1 introduced this file. The legacy ENV var is replaced by
# ACCESS_IQ_ENV. All other runtime config keys are prefixed ACCESS_IQ_.
# Secrets in ECS come from `valueFrom` (Secrets Manager); locally use this file.

ACCESS_IQ_ENV=dev
ACCESS_IQ_AWS_REGION=eu-west-2
ACCESS_IQ_PLATFORM_BUCKET=access-iq-dev-222308823356
ACCESS_IQ_AWS_PROFILE=access-iq-dev
ACCESS_IQ_PSEUDONYM_KEY_SECRET_ARN=
ACCESS_IQ_LAKE_KMS_KEY_ARN=

# JSON-encoded nested structures (validated via inner pydantic models):
ACCESS_IQ_POSTGRES_SOURCES={"ehr_postgres": {"dsn_env": "EHR_DSN", "tables": ["patient_demographics","encounters"]}, "urgent_care_postgres": {"dsn_env": "URGENT_CARE_DSN", "tables": ["urgent_care_logs"]}}
ACCESS_IQ_SFTP_SOURCES={"appointments": {"host_env":"SFTP_HOST","port_env":"SFTP_PORT","user_env":"SFTP_USER","private_key_env":"SFTP_PRIVATE_KEY","remote_dir":"/outbound/appointments/","source_name":"sftp_appointments"}}
ACCESS_IQ_TRUST_S3={"base":{"bucket":"northshire-trust-external-exports","profile":"access-iq-dev-ingestion"},"diagnostics":{"prefix_root":"diagnostics","source_name":"trust_s3_diagnostics"},"provider_ref":{"key":"providers/sites_and_services_master.xlsx","source_name":"trust_s3_provider_ref"}}

# Per-source secret env vars (referenced by *_env fields above):
EHR_DSN=
URGENT_CARE_DSN=
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PRIVATE_KEY=

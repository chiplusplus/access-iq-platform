{
  "app_name": "access-iq",
  "env_name": "dev",
  "account_id": "<your-platform-account-id>",
  "user_name": "<your-sso-role-path>",
  "region": "eu-west-2",
  "tags": {
    "Environment": "dev",
    "Project": "access-iq",
    "ManagedBy": "cdk",
    "CostCenter": "project"
  },
  "s3": {
    "removal_policy": "DESTROY"
  },
  "iam": {
    "external_bucket": "<your-trust-exports-bucket>",
    "trust_account_id": "<your-trust-account-id>"
  },
  "vpc": {
    "platform_cidr": "10.10.0.0/16",
    "trust_cidr": "10.0.0.0/16",
    "max_azs": 3,
    "nat_gateways": 1
  },
  "ecs": {
    "cpu": 512,
    "memory_limit_mib": 1024
  },
  "obs": {
    "log_retention_days": 7,
    "alert_email": "<your-alert-email>",
    "slack_channel_id": "",
    "slack_workspace_id": "",
    "slack_webhook_url": ""
  },
  "redshift": {
    "base_capacity": 8,
    "usage_limit_rpu_hours": 4,
    "snapshot_retention_days": 7,
    "db_name": "dev"
  }
}
